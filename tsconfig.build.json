{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "docs",
    "**/vendor/**",
    "src/test/**/*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
