{
  "name": "deform",
  "version": "0.1.0",
  "description": "An open-source form builder that renders forms from structured config",
  "type": "module",
  "alias": {
    "deform": "./src/index.ts"
  },
  "targets": {
    "lib": {
      "source": "src/index.ts",
      "distDir": "dist",
      "outputFormat": "esmodule"
    },
    "playground": {
      "source": "playground/index.html",
      "distDir": "playground/dist"
    }
  },
  "typings": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "parcel build --target lib && npm run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:watch": "parcel watch --target lib",
    "dev": "npm run build:watch",
    "playground": "parcel playground/index.html --port 8000 --no-source-maps",
    "playground:build": "parcel build playground/index.html --dist-dir playground/dist --public-url ./ --no-source-maps",
    "type-check": "tsc --noEmit",
    "lint:biome": "biome check .",
    "lint:biome:fix": "biome check --write .",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:eslint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint": "npm run lint:biome && npm run lint:eslint",
    "lint:fix": "npm run lint:biome:fix && npm run lint:eslint:fix",
    "format": "biome format --write .",
    "clean": "rm -rf dist .parcel-cache playground/dist playground/.parcel-cache",
    "prebuild": "npm run clean",
    "test": "npm run type-check && npm run lint"
  },
  "keywords": [
    "form",
    "builder",
    "renderer",
    "web-components",
    "typescript"
  ],
  "author": "DeForm Team",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@parcel/transformer-typescript-tsc": "^2.16.3",
    "@parcel/transformer-typescript-types": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "esbuild": "^0.25.9",
    "eslint": "^8.56.0",
    "parcel": "^2.16.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@shoelace-style/shoelace": "^2.20.1",
    "lit": "^3.3.1"
  }
}
